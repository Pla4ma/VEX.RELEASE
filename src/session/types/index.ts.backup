import{z}from'zod'; import{SessionMode,SessionModeSchema}from'../modes'; export const SessionStatusSchema = z.enum(['PREPARING','STARTING','ACTIVE','PAUSED','BACKGROUNDED','INTERRUPTION_RISK','DEGRADED','COMPLETING','COMPLETED','PARTIAL','ABANDONED','FAILED','RECOVERING','CONFLICT']); export type SessionStatus=z.infer<typeof SessionStatusSchema>; export const SessionPhaseSchema = z.enum(['FOCUS','SHORT_BREAK','LONG_BREAK','PREPARATION','REVIEW']); export type SessionPhase=z.infer<typeof SessionPhaseSchema>; export const SessionPresetSchema = z.object({id:z.string().uuid(),name:z.string().min(1).max(100),description:z.string().max(500).optional(),duration:z.number().min(60).max(86400),breakDuration:z.number().min(0).max(3600).default(300),longBreakDuration:z.number().min(0).max(7200).default(900),intervals:z.number().min(1).max(20).default(1),longBreakInterval:z.number().min(1).max(10).default(4),isDefault:z.boolean().default(false),category:z.string().optional(),tags:z.array(z.string()).default([]),soundEnabled:z.boolean().default(true),vibrationEnabled:z.boolean().default(true),dndEnabled:z.boolean().default(false),strictMode:z.boolean().default(false),autoStartBreaks:z.boolean().default(false),autoStartNextInterval:z.boolean().default(false),createdAt:z.number(),updatedAt:z.number(),userId:z.string().optional()}); export type SessionPreset=z.infer<typeof SessionPresetSchema>; export const SessionConfigSchema = z.object({presetId:z.string().uuid().optional(),customName:z.string().max(100).optional(),duration:z.number().min(60).max(86400),breakDuration:z.number().min(0).max(3600),longBreakDuration:z.number().min(0).max(7200),intervals:z.number().min(1).max(20),longBreakInterval:z.number().min(1).max(10),soundEnabled:z.boolean().default(true),vibrationEnabled:z.boolean().default(true),dndEnabled:z.boolean().default(false),strictMode:z.boolean().default(false),autoStartBreaks:z.boolean().default(false),autoStartNextInterval:z.boolean().default(false),category:z.string().optional(),tags:z.array(z.string()).default([]),notes:z.string().max(1000).optional(),goal:z.string().max(500).optional(),estimatedTaskCount:z.number().min(1).max(50).optional(),comebackMultiplier:z.number().min(1).max(3).optional(),sessionMode:SessionModeSchema.default(SessionMode.LIGHT_FOCUS),studyPlanId:z.string().optional(),quizBonusPoints:z.number().min(0).default(0),creativeMoodBonus:z.number().min(0).max(10).default(0),sprintChainCount:z.number().min(1).max(4).default(1),warContext:z.object({squadWarId:z.string().uuid(),squadId:z.string().uuid()}).nullable().optional()}); export type SessionConfig=z.infer<typeof SessionConfigSchema>; export const SessionStateSchema = z.object({id:z.string().uuid(),userId:z.string(),status:SessionStatusSchema,phase:SessionPhaseSchema,config:SessionConfigSchema,startTime:z.number().optional(),startedAt:z.number().optional(),pausedAt:z.number().optional(),pauseStartTime:z.number().optional(),resumedAt:z.number().optional(),completedAt:z.number().optional(),completedAtTime:z.number().optional(),abandonedAt:z.number().optional(),endedAt:z.number().optional(),endTime:z.number().optional(),totalDuration:z.number().default(0),elapsedTime:z.number().default(0),effectiveTime:z.number().default(0),pausedTime:z.number().default(0),remainingTime:z.number(),currentInterval:z.number().min(1).default(1),totalIntervals:z.number().min(1),intervalsCompleted:z.number().min(0).default(0),interruptions:z.number().min(0).default(0),pauses:z.number().min(0).default(0),backgroundTime:z.number().min(0).default(0),totalBackgroundTime:z.number().min(0).default(0),backgroundedAt:z.number().optional(),totalPausedTime:z.number().min(0).default(0),lastPauseReason:z.string().optional(),baseScore:z.number().min(0).default(0),timeBonus:z.number().min(0).default(0),streakBonus:z.number().min(0).default(0),focusQuality:z.number().min(0).max(100).default(100),completionPercentage:z.number().min(0).max(100).default(0),damagePoints:z.number().min(0).default(0),penaltyMultiplier:z.number().min(0).max(1).default(1),recoveryAttempts:z.number().min(0).default(0),maxRecoveryAttempts:z.number().min(0).default(3),lastRecoveryAt:z.number().optional(),deviceId:z.string(),appVersion:z.string(),osVersion:z.string(),antiCheatStatus:z.enum(['CLEAN','WARNING','FLAGGED','FAILED','INVALIDATED']).default('CLEAN'),antiCheatFlags:z.array(z.string()).default([]),createdAt:z.number(),updatedAt:z.number(),syncedAt:z.number().optional(),lastSyncAt:z.number().optional(),isDirty:z.boolean().default(true),metadata:z.record(z.unknown()).optional(),abandonReason:z.string().optional(),failedAt:z.number().optional(),failReason:z.string().optional(),error:z.string().optional(),canRecover:z.boolean().default(false),conflictStatus:z.enum(['NONE','DETECTED','RESOLVED','PENDING']).default('NONE'),storageStatus:z.enum(['HEALTHY','DEGRADED','UNAVAILABLE']).default('HEALTHY')}); export type SessionState=z.infer<typeof SessionStateSchema>; export const SessionSummarySchema = z.object({sessionId:z.string().uuid(),userId:z.string(),status:SessionStatusSchema,plannedDuration:z.number(),actualDuration:z.number(),effectiveDuration:z.number(),pausedDuration:z.number(),completionPercentage:z.number().min(0).max(100),focusQuality:z.number().min(0).max(100),focusPurityScore:z.number().min(0).max(100).default(100),interruptions:z.number(),pauses:z.number(),baseScore:z.number(),timeBonus:z.number(),streakBonus:z.number(),finalScore:z.number(),xpEarned:z.number(),coinsEarned:z.number(),gemsEarned:z.number(),streakMaintained:z.boolean(),streakIncreased:z.boolean(),streakDays:z.number(),userLevel:z.number().int().min(1).default(1),isPerfect:z.boolean().default(false),damageTaken:z.number(),penaltiesApplied:z.array(z.string()),damage:z.object({totalDamage:z.number(),finalPenalty:z.number()}).optional(),bonuses:z.array(z.object({type:z.string(),amount:z.number(),description:z.string()})).default([]),vsAverage:z.number(),vsBest:z.number(),tasksCompleted:z.number().optional(),tasksPlanned:z.number().optional(),reflection:z.string().optional(),mood:z.enum(['GREAT','GOOD','OKAY','STRUGGLING','DIFFICULT']).optional(),sessionMode:SessionModeSchema.default(SessionMode.LIGHT_FOCUS),modeBonus:z.number().min(0).default(0),createdAt:z.number()}); export type SessionSummary=z.infer<typeof SessionSummarySchema>; export const SessionHistoryEntrySchema = z.object({sessionId:z.string().uuid(),userId:z.string(),status:SessionStatusSchema,config:SessionConfigSchema,summary:SessionSummarySchema.optional(),startedAt:z.number(),endedAt:z.number().optional(),createdAt:z.number()}); export type SessionHistoryEntry=z.infer<typeof SessionHistoryEntrySchema>; export const TimerStateSchema = z.object({isRunning:z.boolean().default(false),isPaused:z.boolean().default(false),startTime:z.number().optional(),pauseTime:z.number().optional(),totalPausedTime:z.number().default(0),lastTickAt:z.number().optional(),intervalId:z.any().optional()}); export type TimerState=z.infer<typeof TimerStateSchema>; export const InterruptionTypeSchema = z.enum(['USER_PAUSE','USER_EXIT','PHONE_CALL','NOTIFICATION','LOW_BATTERY','APP_BACKGROUND','SYSTEM_ALERT','DISTURBANCE_DETECTED','NETWORK_LOST','DEVICE_LOCK']); export type InterruptionType=z.infer<typeof InterruptionTypeSchema>; export const InterruptionSeveritySchema = z.enum(['MINOR','MODERATE','MAJOR','CRITICAL']); export type InterruptionSeverity=z.infer<typeof InterruptionSeveritySchema>; export const InterruptionRecordSchema = z.object({id:z.string().uuid(),sessionId:z.string().uuid(),type:InterruptionTypeSchema,severity:InterruptionSeveritySchema,occurredAt:z.number(),duration:z.number().optional(),recoveredAt:z.number().optional(),resolvedAt:z.number().optional(),autoRecovered:z.boolean().default(false),impact:z.object({timeLost:z.number().default(0),scoreImpact:z.number().default(0),damagePoints:z.number().default(0)}).default({}),metadata:z.record(z.unknown()).optional()}); export type InterruptionRecord=z.infer<typeof InterruptionRecordSchema>; export const RecoveryTypeSchema = z.enum(['AUTO_RESUME','USER_RESUME','STREAK_SAVE','PARTIAL_CREDIT','FULL_RESET']); export type RecoveryType=z.infer<typeof RecoveryTypeSchema>; export const RecoveryRecordSchema = z.object({id:z.string().uuid(),sessionId:z.string().uuid(),type:RecoveryTypeSchema,attemptedAt:z.number(),successful:z.boolean(),recoveredTime:z.number().default(0),penalties:z.array(z.object({type:z.string(),amount:z.number(),description:z.string()})).default([]),metadata:z.record(z.unknown()).optional()}); export type RecoveryRecord=z.infer<typeof RecoveryRecordSchema>; export const FocusQualityMetricsSchema = z.object({sessionId:z.string().uuid(),timeInDeepFocus:z.number().default(0),timeInShallowFocus:z.number().default(0),timeDistracted:z.number().default(0),focusSegments:z.array(z.object({startAt:z.number(),endAt:z.number(),duration:z.number(),quality:z.number().min(0).max(100)})).default([]),consistencyScore:z.number().min(0).max(100).default(100),depthScore:z.number().min(0).max(100).default(100),recoveryScore:z.number().min(0).max(100).default(100),overallScore:z.number().min(0).max(100).default(100),calculatedAt:z.number()}); export type FocusQualityMetrics=z.infer<typeof FocusQualityMetricsSchema>; export const AntiCheatFlagSchema = z.object({id:z.string().uuid(),sessionId:z.string().uuid(),type:z.enum(['TIME_MANIPULATION','IMPOSSIBLE_DURATION','RAPID_COMPLETION','DEVICE_CHANGE','LOCATION_SPOOF','AUTOMATION_DETECTED','INCONSISTENT_DATA','MULTIPLE_INSTANCES','SUSPICIOUS_PATTERN']),severity:z.enum(['WARNING','MODERATE','CRITICAL']),detectedAt:z.number(),evidence:z.record(z.unknown()),actionTaken:z.enum(['NONE','FLAGGED','SCORE_REDUCED','SESSION_INVALIDATED']).default('NONE'),score:z.number().optional()}); export type AntiCheatFlag=z.infer<typeof AntiCheatFlagSchema>; export interface SessionEvents{'session:created':{sessionId:string;userId:string;config:SessionConfig;timestamp:number};'session:starting':{sessionId:string;countdown:number;timestamp:number};'session:started':{sessionId:string;startedAt:number;phase:SessionPhase};'session:paused':{sessionId:string;pausedAt:number;reason?:InterruptionType};'session:resumed':{sessionId:string;resumedAt:number;pausedDuration:number};'session:phase:changed':{sessionId:string;previousPhase:SessionPhase;newPhase:SessionPhase;timestamp:number};'session:interval:completed':{sessionId:string;interval:number;timestamp:number};'session:completing':{sessionId:string;timestamp:number};'session:completed':{sessionId:string;summary:SessionSummary;timestamp:number};'session:partial':{sessionId:string;summary:SessionSummary;timestamp:number};'session:abandoned':{sessionId:string;abandonedAt:number;reason?:string};'session:failed':{sessionId:string;error:string;timestamp:number};'session:tick':{sessionId:string;elapsed:number;remaining:number;percentage:number};'session:progress':{sessionId:string;phase:SessionPhase;interval:number;percentage:number};'session:interruption':{sessionId:string;interruption:InterruptionRecord};'session:interruption:risk':{sessionId:string;riskLevel:'LOW'|'MEDIUM'|'HIGH'|'CRITICAL'};'session:backgrounded':{sessionId:string;backgroundedAt:number};'session:foregrounded':{sessionId:string;foregroundedAt:number;duration:number};'session:recovery:attempted':{sessionId:string;recovery:RecoveryRecord};'session:recovery:successful':{sessionId:string;recoveredAt:number;recoveredTime:number};'session:recovery:failed':{sessionId:string;failedAt:number;reason:string};'session:score:updated':{sessionId:string;score:number;previousScore:number;reason:string};'session:bonus:earned':{sessionId:string;type:string;amount:number};'session:damage:taken':{sessionId:string;amount:number;reason:string};'session:anticheat:flag':{sessionId:string;flag:AntiCheatFlag};'session:anticheat:cleared':{sessionId:string;clearedAt:number};'session:sync:started':{sessionId:string;timestamp:number};'session:sync:completed':{sessionId:string;timestamp:number};'session:sync:failed':{sessionId:string;error:string;timestamp:number};'session:conflict:detected':{sessionId:string;localState:SessionState;remoteState:SessionState}}export const TimerConfigSchema = z.object({tickInterval:z.number().min(100).max(5000).default(1000),backgroundTickInterval:z.number().min(1000).max(30000).default(5000),pauseThreshold:z.number().min(1000).max(60000).default(5000),maxPauseDuration:z.number().min(60000).max(86400000).default(3600000),warningThresholds:z.array(z.number()).default([300,60,10])}); export type TimerConfig=z.infer<typeof TimerConfigSchema>; export const ScoreCalculationSchema = z.object({basePoints:z.number(),timeMultiplier:z.number().min(0.5).max(3),streakMultiplier:z.number().min(1).max(5),qualityMultiplier:z.number().min(0.5).max(1.5),penaltyMultiplier:z.number().min(0).max(1),comebackMultiplier:z.number().min(1).max(3).default(1),bonusPoints:z.number().default(0),isPerfect:z.boolean().default(false),timeBonus:z.number().default(0),streakBonus:z.number().default(0),qualityBonus:z.number().default(0),intervalBonus:z.number().default(0),comebackBonus:z.number().default(0),pausePenalty:z.number().default(0),interruptionPenalty:z.number().default(0),qualityPenalty:z.number().default(0),antiCheatPenalty:z.number().default(0)}); export type ScoreCalculation=z.infer<typeof ScoreCalculationSchema>; export const DamageCalculationSchema = z.object({baseDamage:z.number().min(0),pauseDamage:z.number().min(0).default(0),interruptionDamage:z.number().min(0).default(0),abandonDamage:z.number().min(0).default(0),antiCheatDamage:z.number().min(0).default(0),mitigation:z.number().min(0).max(1).default(0),streakProtection:z.boolean().default(false),totalDamage:z.number().min(0),finalPenalty:z.number().min(0).max(1)}); export type DamageCalculation=z.infer<typeof DamageCalculationSchema>; export const SessionUIStateSchema = z.enum(['PRE_SESSION','STARTING','ACTIVE','PAUSED','RESUMED','BACKGROUNDED','INTERRUPTION_RISK','RECONNECTING','DEGRADED','COMPLETION_SUCCESS','PARTIAL_COMPLETION','FAILURE_ABANDON','CONFLICT','POST_REWARD']); export type SessionUIState=z.infer<typeof SessionUIStateSchema>; export const SessionNotificationTypeSchema = z.enum(['STARTING','COMPLETED','PAUSED_LONG','STREAK_AT_RISK','FOCUS_QUALITY_DROP','INTERVAL_COMPLETE','BREAK_STARTING','RECOVERY_AVAILABLE','SYNCS_CONFLICT']); export type SessionNotificationType=z.infer<typeof SessionNotificationTypeSchema>; export interface SyncConflict{sessionId:string;localState:SessionState;remoteState:SessionState;detectedAt:number;resolution?:'LOCAL'|'REMOTE'|'MERGED';resolvedAt?:number}export interface CompletionResult{success:boolean;summary:SessionSummary;error?:string;canRecover?:boolean;status:'COMPLETED'|'PARTIAL_COMPLETE'|'FAILED'}export interface AbandonResult{damage:{totalDamage:number;finalPenalty:number};canRecover:boolean}export interface SessionCreationResult{success:boolean;session:SessionState|null;error?:string}export interface StateTransitionResult{success:boolean;session:SessionState;error?:string}export interface ServiceOperationResult<T=void>{success:boolean;data?:T;error?:string;errorCode?:string}export interface TimeCalculationResult{elapsed:number;remaining:number;duration:number;percentage:number;effectiveTime:number;pausedDuration:number;backgroundTime:number}export interface TimeBreakdown{hours:number;minutes:number;seconds:number;totalSeconds:number;formatted:string}export interface TimeProgressMetrics{elapsed:number;remaining:number;duration:number;percentage:number;isComplete:boolean;isNearComplete:boolean;progressRatio:number;phase:string;interval:number;estimatedCompletionTime:number}export type TimeStatus='PENDING'|'ACTIVE'|'PAUSED'|'COMPLETE'|'OVERDUE'; export*from'./events';
