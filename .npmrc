# npm configuration for VEX
#
# Required by Expo SDK 57 + RN 0.86 transitive peer landscape (react@19,
# reanimated@4, worklets, bottom-sheet, skia, sentry, …). Without this,
# EAS Cloud workers abort with ERESOLVE during `npm ci --include=dev` — flag
# priorities: CLI flag > env > project .npmrc > global config. We rely on
# `.npmrc` here because EAS does not pass `--legacy-peer-deps` on its own.
legacy-peer-deps=true
