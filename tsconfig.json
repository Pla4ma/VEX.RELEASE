{
  "compilerOptions": {
    "target": "ES2020",
    "jsx": "react-native",
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noUncheckedIndexedAccess": true,
    "strictFunctionTypes": true,
    "strictPropertyInitialization": true,
    "noImplicitThis": true,
    "alwaysStrict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "paths": {
      "@/*": ["./src/*"],
      "@components/*": ["./src/components/*"],
      "@hooks/*": ["./src/hooks/*"],
      "@theme/*": ["./src/theme/*"]
    },
    "allowSyntheticDefaultImports": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "isolatedModules": true,
    "noEmit": true,
    "types": [
      "react",
      "react-native",
      "jest",
      "node"
    ]
  },
  "include": [
    "src/**/*",
    "index.js",
    "App.tsx",
    "src/types/**/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "android",
    "ios",
    "archive",
    "__tests__/**/*",
    "**/*.test.ts",
    "**/*.test.tsx",
    "src/features/__tests__/helpers/**/*",
    "src/features/home-experience/__tests__/helpers/**/*",
    "src/session/__tests__/helpers.ts",
    "src/session/__tests__/persistence.helpers.ts",
    "src/session/__tests__/persistence/helpers.ts",
    "src/session/__tests__/SessionOrchestrator.helpers.ts",
    "src/session/engines/__tests__/helpers.ts",
    "src/session/engines/__tests__/TimerEngine.helpers.ts",
    "src/session/engines/__tests__/TimerEngine/helpers.ts",
    "src/session/integration/__tests__/helpers/**/*",
    "src/session/integration/__tests__/helpers.ts"
  ],
  "extends": "expo/tsconfig.base.json"
}
