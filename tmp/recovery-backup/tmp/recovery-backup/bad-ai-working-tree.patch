+export function detectNearMiss(streak: Streak): boolean {
+  if (streak.currentDays === 0 || !streak.lastQualifyingSessionAt) {
+    return false;
+  }
+  
+  // Near miss if current time is within 1 hour of the 24h deadline
+  const deadline = streak.lastQualifyingSessionAt + (24 * 60 * 60 * 1000);
+  const timeToDeadline = deadline - Date.now();
+  const oneHour = 60 * 60 * 1000;
+
+  return timeToDeadline > 0 && timeToDeadline < oneHour;
 }
