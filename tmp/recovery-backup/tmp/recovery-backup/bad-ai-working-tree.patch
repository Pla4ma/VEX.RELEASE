     percentComplete,
     criticalHit: false, // Critical is calculated before this call
   };
+}
+
+export async function processBossTurn(encounterId: string, input: { sessionQuality: number; pauseSeconds: number }): Promise<BossEncounter | null> {
+  const encounter = await repository.fetchEncounterById(encounterId);
+  if (!encounter || encounter.status !== 'ACTIVE') return null;
+
+  let recoveryAmount = 0;
+  
+  // Rule 1: Poor session quality heals the boss (Boss "Feeds" on lack of focus)
+  if (input.sessionQuality < 40) {
+    recoveryAmount += Math.floor(encounter.maxHealth * 0.05); // 5% heal
+  }
+
+  // Rule 2: Long pauses heal the boss (Regeneration while player is away)
+  if (input.pauseSeconds > 300) {
+    recoveryAmount += Math.floor(encounter.maxHealth * 0.1); // 10% heal
+  }
+
+  if (recoveryAmount > 0) {
+    const updated = await repository.recoverBossHealth(encounterId, recoveryAmount);
+    
+    eventBus.publish('boss:recovered', {
+      encounterId,
+      recoveryAmount,
+      newHealth: updated.healthRemaining,
+      reason: input.sessionQuality < 40 ? 'LOW_QUALITY' : 'LONG_PAUSE',
+    });
+
+    return updated;
+  }
+
+  return encounter;
 }
