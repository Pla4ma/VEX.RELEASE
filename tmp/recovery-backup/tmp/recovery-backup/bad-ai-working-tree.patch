   if (error) {
     throw new RepositoryError('recordBossDefeat', error);
   }
+}
+
+export async function recoverBossHealth(encounterId: string, recoveryAmount: number): Promise<BossEncounter> {
+  const { data: current, error: fetchError } = await supabase
+    .from('boss_encounters')
+    .select('health_remaining, max_health')
+    .eq('id', encounterId)
+    .single();
+
+  if (fetchError) throw new RepositoryError('recoverBossHealth:fetch', fetchError);
+
+  const newHealth = Math.min(current.max_health, current.health_remaining + recoveryAmount);
+
+  const { data, error } = await supabase
+    .from('boss_encounters')
+    .update({
+      health_remaining: newHealth,
+      updated_at: Date.now(),
+    })
+    .eq('id', encounterId)
+    .select()
+    .single();
+
+  if (error) throw new RepositoryError('recoverBossHealth', error);
+  return BossEncounterSchema.parse(data);
 }
