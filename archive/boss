/**
 * Boss Narrative System
 *
 * Phase 3.1 - Boss Battle System Overhaul
 * Transforms boss battles into emotional core of the app with:
 * - Narrative arcs with story phases
 * - Boss phases: FULL_HEALTH → WOUNDED → DESPERATE → DEFEATED
 * - Visual themes and tension music per phase
 * - Boss personality taunts at each phase
 *
 * Dependencies:
 * - Boss Service (encounter tracking)
 * - Session Integration (damage dealt triggers phase changes)
 * - Audio Service (phase-based music)
 * - Analytics (engagement tracking)
 */

import { eventBus } from '../../events';

// ============================================================================
// Types
// ============================================================================

export type BossPhase = 'FULL_HEALTH' | 'WOUNDED' | 'DESPERATE' | 'DEFEATED';

export interface BossNarrativeArc {
  bossId: string;
  bossName: string;
  theme: BossTheme;
  story: string;
  phases: Record<BossPhase, PhaseNarrative>;
}

export interface PhaseNarrative {
  name: string;
  description: string;
  visualTheme: VisualTheme;
  musicMood: MusicMood;
  taunts: string[];
  entryThreshold: number; // Percent health to enter this phase
  effects: PhaseEffects;
}

export interface VisualTheme {
  backgroundGradient: [string, string]; // [start, end] colors
  particleEffect: 'none' | 'embers' | 'dark_mist' | 'crackling_energy' | 'victory_sparkles';
  bossTint: string; // hex color overlay
  screenShake: 'none' | 'subtle' | 'moderate' | 'intense';
}

export type MusicMood = 'ominous' | 'tense' | 'desperate' | 'triumphant' | 'ambient';

export interface PhaseEffects {
  damageMultiplier: number; // Damage dealt TO boss is multiplied by this
  bossRetaliationChance: number; // 0-1 chance of boss "fighting back" visually
  criticalHitBonus: number; // Bonus to critical hit chance
}

export interface BossPhaseState {
  encounterId: string;
  currentPhase: BossPhase;
  previousPhase: BossPhase | null;
  phaseEnteredAt: number;
  totalDamageInPhase: number;
  tauntsShown: string[];
}

export interface BossTheme {
  id: string;
  name: string;
  description: string;
  icon: string;
  colorPalette: {
    primary: string;
    secondary: string;
    accent: string;
  };
}

