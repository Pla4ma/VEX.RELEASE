// ============================================================================
// Boss Phase Management
// ============================================================================

/**
 * Get the narrative arc for a boss
 */
export function getBossNarrativeArc(bossId: string): BossNarrativeArc | null {
  return BOSS_NARRATIVE_ARCS[bossId] || null;
}

/**
 * Determine the current phase based on health percentage
 */
export function determineBossPhase(healthPercent: number): BossPhase {
  if (healthPercent <= 0) {return 'DEFEATED';}
  if (healthPercent <= 25) {return 'DESPERATE';}
  if (healthPercent <= 50) {return 'WOUNDED';}
  return 'FULL_HEALTH';
}

/**
 * Calculate health percentage
 */
export function calculateHealthPercent(healthRemaining: number, maxHealth: number): number {
  return Math.max(0, Math.min(100, (healthRemaining / maxHealth) * 100));
}

/**
 * Get phase narrative details
 */
export function getPhaseNarrative(bossId: string, phase: BossPhase): PhaseNarrative | null {
  const arc = getBossNarrativeArc(bossId);
  if (!arc) {return null;}
  return arc.phases[phase];
}

/**
 * Get a random taunt for the current phase
 */
export function getRandomTaunt(bossId: string, phase: BossPhase, shownTaunts: string[] = []): string | null {
  const phaseNarrative = getPhaseNarrative(bossId, phase);
  if (!phaseNarrative) {return null;}

  const availableTaunts = phaseNarrative.taunts.filter((t) => !shownTaunts.includes(t));

  if (availableTaunts.length === 0) {
    // Reset and use all taunts again
    return phaseNarrative.taunts[Math.floor(Math.random() * phaseNarrative.taunts.length)];
  }

  return availableTaunts[Math.floor(Math.random() * availableTaunts.length)];
}

/**
 * Get current visual theme for boss encounter
 */
export function getCurrentVisualTheme(
  bossId: string,
  healthRemaining: number,
  maxHealth: number
): VisualTheme | null {
  const healthPercent = calculateHealthPercent(healthRemaining, maxHealth);
  const phase = determineBossPhase(healthPercent);
  const phaseNarrative = getPhaseNarrative(bossId, phase);
  return phaseNarrative?.visualTheme || null;
}

/**
 * Get current music mood for boss encounter
 */
export function getCurrentMusicMood(
  bossId: string,
  healthRemaining: number,
  maxHealth: number
): MusicMood {
  const healthPercent = calculateHealthPercent(healthRemaining, maxHealth);
  const phase = determineBossPhase(healthPercent);
  const phaseNarrative = getPhaseNarrative(bossId, phase);
  return phaseNarrative?.musicMood || 'ambient';
}

/**
 * Get phase effects for damage calculation
 */
export function getPhaseEffects(
  bossId: string,
  healthRemaining: number,
  maxHealth: number
): PhaseEffects {
  const healthPercent = calculateHealthPercent(healthRemaining, maxHealth);
  const phase = determineBossPhase(healthPercent);
  const phaseNarrative = getPhaseNarrative(bossId, phase);
  return (
    phaseNarrative?.effects || {
      damageMultiplier: 1.0,
      bossRetaliationChance: 0,
      criticalHitBonus: 0,
    }
  );
}

// ============================================================================
// Boss Phase State Management
// ============================================================================

const phaseStateMap = new Map<string, BossPhaseState>();

/**
 * Initialize phase state for an encounter
 */
export function initializePhaseState(encounterId: string, bossId: string): BossPhaseState {
  const state: BossPhaseState = {
    encounterId,
    currentPhase: 'FULL_HEALTH',
    previousPhase: null,
    phaseEnteredAt: Date.now(),
    totalDamageInPhase: 0,
    tauntsShown: [],
  };
  phaseStateMap.set(encounterId, state);
  return state;
}

/**
 * Update phase state after damage is dealt
 * Returns true if phase changed
 */
export function updatePhaseState(
  encounterId: string,
  bossId: string,
  healthRemaining: number,
  maxHealth: number,
  damageDealt: number
): { phaseChanged: boolean; newPhase: BossPhase; previousPhase: BossPhase | null } {
  let state = phaseStateMap.get(encounterId);
  if (!state) {
    state = initializePhaseState(encounterId, bossId);
  }

  const healthPercent = calculateHealthPercent(healthRemaining, maxHealth);
  const newPhase = determineBossPhase(healthPercent);
  const previousPhase = state.currentPhase;

  state.totalDamageInPhase += damageDealt;

  if (newPhase !== state.currentPhase) {
    state.previousPhase = state.currentPhase;
    state.currentPhase = newPhase;
    state.phaseEnteredAt = Date.now();
    state.totalDamageInPhase = damageDealt;
    state.tauntsShown = [];

    // Publish phase change event
    eventBus.publish('boss:phase_changed', {
      encounterId,
      bossId,
      previousPhase,
      newPhase,
      healthPercent,
    });

    return { phaseChanged: true, newPhase, previousPhase };
  }

  return { phaseChanged: false, newPhase: state.currentPhase, previousPhase: null };
}

/**
 * Get current phase state
 */
export function getPhaseState(encounterId: string): BossPhaseState | null {
  return phaseStateMap.get(encounterId) || null;
}

/**
 * Record that a taunt was shown
 */
export function recordTauntShown(encounterId: string, taunt: string): void {
  const state = phaseStateMap.get(encounterId);
  if (state) {
    state.tauntsShown.push(taunt);
  }
}

/**
 * Clear phase state for an encounter
 */
export function clearPhaseState(encounterId: string): void {
  phaseStateMap.delete(encounterId);
}

// ============================================================================
// Boss Story Helpers
// ============================================================================

/**
 * Get boss story summary
 */
export function getBossStory(bossId: string): string | null {
  const arc = getBossNarrativeArc(bossId);
  return arc?.story || null;
}

/**
 * Get boss theme details
 */
export function getBossTheme(bossId: string): BossTheme | null {
  const arc = getBossNarrativeArc(bossId);
  return arc?.theme || null;
}

/**
 * Check if boss has narrative arc
 */
export function hasNarrativeArc(bossId: string): boolean {
  return bossId in BOSS_NARRATIVE_ARCS;
}

/**
 * Get all available narrative arcs
 */
export function getAllNarrativeArcs(): BossNarrativeArc[] {
  return Object.values(BOSS_NARRATIVE_ARCS);
}

