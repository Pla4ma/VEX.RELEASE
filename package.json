{
  "name": "vex-app",
  "version": "1.0.0",
  "private": true,
  "description": "VEX: gamified productivity/focus app built around one daily focus loop.",
  "main": "App.js",
  "scripts": {
    "android": "expo run:android",
    "ios": "expo run:ios",
    "start": "expo start",
    "web": "expo start --web",
    "start:web": "expo start --web",
    "test": "jest --config jest.config.js",
    "test:app": "jest --config jest.config.js",
    "test:jobs": "jest --config jest.config.jobs.js",
    "test:watch": "jest --config jest.config.js --watch",
    "test:coverage": "jest --config jest.config.js --coverage",
    "test:e2e": "detox test",
    "test:e2e:build": "detox build",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "check:no-ts-nocheck": "node scripts/check-no-ts-nocheck.js",
    "types:supabase": "node scripts/generate-supabase-types.js",
    "clean": "react-native clean",
    "pod-install": "cd ios && pod install && cd ..",
    "perf:audit": "node scripts/performance-audit.js",
    "docs:generate": "npx typedoc --out docs/api src",
    "storybook": "start-storybook -p 7007",
    "storybook:build": "build-storybook -o docs/storybook"
  },
  "dependencies": {
    "@gorhom/bottom-sheet": "^5.2.13",
    "@react-native-community/netinfo": "12.0.1",
    "@react-navigation/bottom-tabs": "^6.6.0",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.11.0",
    "@sentry/react-native": "~7.11.0",
    "@shopify/flash-list": "2.0.2",
    "@supabase/supabase-js": "^2.103.3",
    "@tanstack/react-query": "^5.52.0",
    "babel-preset-expo": "~56.0.0",
    "expo": "~56.0.0",
    "expo-build-properties": "^56.0.14",
    "expo-document-picker": "~56.0.4",
    "expo-haptics": "~56.0.3",
    "expo-linear-gradient": "~56.0.4",
    "expo-notifications": "~56.0.13",
    "expo-secure-store": "~56.0.4",
    "expo-status-bar": "~56.0.4",
    "immer": "^10.0.3",
    "posthog-react-native": "^4.42.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-mmkv": "^2.11.0",
    "react-native-purchases": "^10.0.1",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "^0.8.3",
    "zod": "^3.22.4",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/plugin-proposal-decorators": "^7.25.0",
    "@babel/preset-env": "^7.26.0",
    "@babel/runtime": "^7.26.0",
    "@react-native/eslint-config": "^0.74.0",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^12.4.3",
    "@trigger.dev/sdk": "4.4.4",
    "@types/jest": "^29.5.11",
    "@types/node": "^25.6.0",
    "@types/react": "~19.2.14",
    "@types/react-test-renderer": "^19.1.0",
    "@types/uuid": "^9.0.8",
    "babel-jest": "^29.7.0",
    "babel-plugin-module-resolver": "^5.0.0",
    "detox": "^20.18.1",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "jest-expo": "~56.0.4",
    "msw": "^2.13.4",
    "prettier": "^3.1.1",
    "react-test-renderer": "19.1.0",
    "typescript": "~6.0.3",
    "whatwg-fetch": "^3.6.20"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "expo": {
    "install": {}
  }
}
