# VEX App Environment Configuration
# Copy this file to .env.local and fill in your actual values

# ================================
# SUPABASE CONFIGURATION (REQUIRED)
# ================================
# Get these from your Supabase project dashboard
SUPABASE_PROJECT_ID=your-supabase-project-id
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# ================================
# SENTRY ERROR TRACKING (PRODUCTION REQUIRED)
# ================================
# Get this from your Sentry project dashboard
EXPO_PUBLIC_SENTRY_DSN=https://your-sentry-dsn-here

# ================================
# REVENUECAT MONETIZATION (PRODUCTION REQUIRED)
# ================================
# Get these from your RevenueCat project dashboard
EXPO_PUBLIC_REVENUECAT_IOS_KEY=your-ios-revenuecat-key
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=your-android-revenuecat-key

# ================================
# ANALYTICS (OPTIONAL)
# ================================
EXPO_PUBLIC_POSTHOG_KEY=your-posthog-key
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ================================
# APP CONFIGURATION
# ================================
EXPO_USE_EXPO_ROUTER=0
EXPO_PUBLIC_ENABLE_EXPO_GO_SHIMS=1
EXPO_PUBLIC_APP_VERSION=1.0.0
EXPO_PUBLIC_ENVIRONMENT=development
